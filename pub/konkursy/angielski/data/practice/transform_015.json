{
  "title": "Sentence Transformation: Modals & Obligation",
  "type": "practice",
  "tasks": [
    {
      "id": "1",
      "type": "sentence_transformation",
      "points": 6,
      "instruction": "Przeczytaj zdania. Wykorzystując wyrazy podane wielkimi literami, uzupełnij każde zdanie z luką tak, aby precyzyjnie oddać sens zdania wyjściowego. Nie zmieniaj formy podanych wyrazów. W każdą lukę możesz wpisać maksymalnie pięć wyrazów, wliczając w to wyraz już podany.",
      "items": [
        {
          "id": "1.1",
          "original": "It isn't necessary to wear a uniform.",
          "keyword": "HAVE",
          "transformed": "You _________ a uniform.",
          "answer": "don't have to wear"
        },
        {
          "id": "1.2",
          "original": "It is against the rules to use a phone here.",
          "keyword": "ALLOWED",
          "transformed": "You _________ a phone here.",
          "answer": "aren't allowed to use"
        },
        {
          "id": "1.3",
          "original": "Perhaps she is at home now.",
          "keyword": "MIGHT",
          "transformed": "She _________ at home now.",
          "answer": "might be"
        },
        {
          "id": "1.4",
          "original": "I'm sure he forgot the meeting.",
          "keyword": "MUST",
          "transformed": "He _________ the meeting.",
          "answer": "must have forgotten"
        },
        {
          "id": "1.5",
          "original": "It's a good idea for you to see a doctor.",
          "keyword": "SHOULD",
          "transformed": "You _________ a doctor.",
          "answer": "should see"
        },
        {
          "id": "1.6",
          "original": "It was a mistake to leave so early.",
          "keyword": "SHOULDN'T",
          "transformed": "We _________ so early.",
          "answer": "shouldn't have left"
        }
      ]
    }
  ]
}
