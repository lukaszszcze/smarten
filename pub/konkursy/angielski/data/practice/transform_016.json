{
  "title": "Sentence Transformation: Mixed Structures III",
  "type": "practice",
  "tasks": [
    {
      "id": "1",
      "type": "sentence_transformation",
      "points": 6,
      "instruction": "Przeczytaj zdania. Wykorzystując wyrazy podane wielkimi literami, uzupełnij każde zdanie z luką tak, aby precyzyjnie oddać sens zdania wyjściowego. Nie zmieniaj formy podanych wyrazów. W każdą lukę możesz wpisać maksymalnie pięć wyrazów, wliczając w to wyraz już podany.",
      "items": [
        {
          "id": "1.1",
          "original": "I started learning English five years ago.",
          "keyword": "BEEN",
          "transformed": "I _________ English for five years.",
          "answer": "have been learning"
        },
        {
          "id": "1.2",
          "original": "The last time I saw her was in May.",
          "keyword": "SINCE",
          "transformed": "I _________ May.",
          "answer": "haven't seen her since"
        },
        {
          "id": "1.3",
          "original": "It's too cold to go swimming.",
          "keyword": "ENOUGH",
          "transformed": "It _________ to go swimming.",
          "answer": "isn't warm enough"
        },
        {
          "id": "1.4",
          "original": "He is too young to drive a car.",
          "keyword": "OLD",
          "transformed": "He _________ to drive a car.",
          "answer": "isn't old enough"
        },
        {
          "id": "1.5",
          "original": "Someone is cleaning the windows right now.",
          "keyword": "BEING",
          "transformed": "The windows _________ right now.",
          "answer": "are being cleaned"
        },
        {
          "id": "1.6",
          "original": "I regret telling him the truth.",
          "keyword": "WISH",
          "transformed": "I _________ him the truth.",
          "answer": "wish I hadn't told"
        }
      ]
    }
  ]
}
